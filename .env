# LLM backend: transformers | ollama | mock
LLM_BACKEND=ollama

# Transformers backend model
HF_MODEL_NAME=meta-llama/Llama-3.2-3B-Instruct

# Ollama backend model (used only when LLM_BACKEND=ollama)
OLLAMA_MODEL=qwen2.5:7b

# Embedding model for retrieval/indexing
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Inference settings
USE_4BIT=true
TEMPERATURE=0.1
MAX_NEW_TOKENS=384

# Retrieval settings
MAX_RETRIEVAL_LOOPS=2

# Dataset settings
HOTPOT_SUBSET_SIZE=200
HOTPOT_SPLIT=validation
