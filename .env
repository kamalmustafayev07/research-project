# LLM backend: transformers | ollama | mock
LLM_BACKEND=ollama

# Transformers backend model
HF_MODEL_NAME=meta-llama/Llama-3.2-3B-Instruct

# Ollama backend model (used only when LLM_BACKEND=ollama)
OLLAMA_MODEL=llama3.2:3b

# Embedding model for retrieval/indexing
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Inference settings
USE_4BIT=true
TEMPERATURE=0.1
MAX_NEW_TOKENS=384

# Retrieval settings
MAX_RETRIEVAL_LOOPS=2

# Dataset settings
DATASET=hotpotqa
DATASET_SUBSET_SIZE=200
DATASET_SPLIT=validation
TWOWIKI_DATASET_NAME=voidful/2WikiMultihopQA

USE_RERANKER=true
RERANKER_WEIGHT=0.4
RERANKER_NEGATIVES_PER_POSITIVE=3
RERANKER_MAX_TRAIN_EXAMPLES=1200
RERANKER_EPOCHS=12